# Backend Environment Variables

# Server
PORT=5000
NODE_ENV=development

# MongoDB
# Local: mongodb://localhost:27017/unitydrop
# Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/unitydrop
MONGODB_URI=mongodb://localhost:27017/unitydrop

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
